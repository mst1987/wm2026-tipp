# ── Datenbank ────────────────────────────────────────────────────────────────
# Für lokale Entwicklung ohne Docker:
DATABASE_URL="postgresql://wm2026:wm2026@localhost:5432/wm2026"

# Postgres-Zugangsdaten (für Docker Compose)
POSTGRES_USER=wm2026
POSTGRES_PASSWORD=wm2026              # ← in Produktion ändern!
POSTGRES_DB=wm2026

# ── Discord OAuth2 ────────────────────────────────────────────────────────────
# Anlegen unter: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Lokal:      http://localhost:3001/api/auth/discord/callback
# Produktion: https://deine-domain.de/api/auth/discord/callback
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback

# ── Discord Bot (optional) ────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret   # ← unbedingt ändern!
JWT_EXPIRATION=7d

# ── Frontend URL (für CORS & OAuth-Redirect) ──────────────────────────────────
# Lokal:      http://localhost:4200
# Produktion: https://deine-domain.de
FRONTEND_URL=http://localhost:4200

# ── Football-Data API (Ergebnisse & Spielplan) ───────────────────────────────
FOOTBALL_API_KEY=your_football_data_api_key
FOOTBALL_API_BASE_URL=https://api.football-data.org/v4

# ── API-Football (Match-Details: Tore, Aufstellungen, Karten, Wechsel) ────────
# Kostenlos registrieren: https://www.api-football.com/ (100 Anfragen/Tag gratis)
# Direkter Zugang (api-sports.io) — NICHT die RapidAPI-Variante:
API_FOOTBALL_KEY=your_api_football_key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Liga-ID der WM in API-Football ist 1, Saison 2026:
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026

# ── Port (nur für lokale Entwicklung) ────────────────────────────────────────
PORT=3000

# ── Admin ──────────────────────────────────────────────────────────────────────
# Discord-Username des Admin-Benutzers (hat Zugriff auf /admin Dashboard)
ADMIN_USERNAME=devihra
